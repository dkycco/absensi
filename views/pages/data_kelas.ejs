<div class="page-content">
    <div class="container-fluid">

        <div class="row">
            <div class="col-lg-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Data Kelas</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-4 mb-3">
                            <div class="col-sm-auto">
                                <div>
                                    <button type="button" class="btn btn-success add-btn" data-bs-toggle="modal"
                                        id="create-btn" data-bs-target="#addModal"><i
                                            class="ri-add-line align-bottom me-1"></i> Tambah Kelas</button>
                                </div>
                            </div>
                        </div>
                        <table id="scroll-horizontal" class="table nowrap align-middle" style="width:100%">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Tingkat</th>
                                    <th>Jurusan</th>
                                    <th>Nama Kelas</th>
                                    <th>Aksi</th>
                                </tr>
                            </thead>
                            <tbody>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="modal fade" id="addModal" tabindex="-1" aria-labelledby="addModal" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header bg-light p-3">
                        <h5 class="modal-title" id="addModal">Tambah Kelas</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"
                            id="close-modal"></button>
                    </div>
                    <form class="tablelist-form needs-validation" novalidate autocomplete="off">
                        <div class="modal-body">

                            <div class="mb-3">
                                <label for="nisn-field" class="form-label">Tingkat</label>
                                <select class="form-control js-example-basic-single" name="tingkat" required>
                                    <option value="" selected disabled>Pilih tingkat</option>
                                    <optgroup label="Category">
                                        <option value="">Select 1</option>
                                        <option value="">Select 2</option>
                                    </optgroup>
                                </select>
                                <div class="invalid-feedback">Masukan NISN.</div>
                            </div>

                            <div class="mb-3">
                                <label for="nisn-field" class="form-label">Jurusan</label>
                                <select class="form-control js-example-basic-single" name="jurusan" required>
                                    <option value="" selected disabled>Pilih jurusan</option>
                                    <optgroup label="Category">
                                        <option value="">Select 1</option>
                                        <option value="">Select 2</option>
                                    </optgroup>
                                </select>
                                <div class="invalid-feedback">Masukan NISN.</div>
                            </div>

                            <div class="mb-3">
                                <label for="name-field" class="form-label">Nama kelas</label>
                                <input type="text" id="name-field" class="form-control"
                                    placeholder="Masukan nama kelas." disabled />
                                <div class="invalid-feedback">Masukan nama kelas.</div>
                            </div>

                        </div>
                        <div class="modal-footer">
                            <div class="hstack gap-2 justify-content-end">
                                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Tutup</button>
                                <button type="submit" class="btn btn-success" id="add-btn">
                                    <i class="mdi mdi-content-save-all-outline"></i>
                                    Simpan Data</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

    </div>
</div>